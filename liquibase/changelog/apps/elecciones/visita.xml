<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
<changeSet id="create-visita" author="orco">
    <createSequence sequenceName="visita_id_seq" startValue="1" />
    <createTable tableName="visita">
        <column name="id" type="int">
            <constraints primaryKey="true" nullable="false"/>
        </column>
        <column name="is_deleted" type="boolean">
            <constraints nullable="false"/>
        </column>
        <column name="createdby" type="varchar(255)">
        </column>
        <column name="updatedby" type="varchar(255)">
        </column>
        <column name="createdat" type="timestamp">
        </column>
        <column name="updatedat" type="timestamp">
        </column>
        <column name="salida" type="int">
            <constraints nullable="false"/>
        </column>
        <column name="votante" type="int">
            <constraints nullable="false"/>
        </column>
        <column name="lugar" type="uuid">
            <constraints nullable="false"/>
        </column>
        <column name="fecha" type="timestamp">
            <constraints nullable="false"/>
        </column>
        <column name="resultado" type="int">
            <constraints nullable="false"/>
        </column>
        <column name="notas" type="text">
        </column>
    </createTable>
    <addDefaultValue tableName="visita" columnName="id" defaultValueComputed="nextval('visita_id_seq')" />
</changeSet>
</databaseChangeLog>
