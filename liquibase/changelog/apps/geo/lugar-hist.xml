<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

<changeSet id="create-hist_lugar" author="orco">
    <createTable tableName="hist_lugar">
        <column name="history_id" type="bigint"/>
        <column name="history_date" type="timestamp"/>
        <column name="history_type" type="char(1)"/>
        <column name="history_user_id" type="bigint"/>
        <column name="history_change_reason" type="text"/>
        <column name="id" type="uuid"/>
        <column name="is_deleted" type="boolean"/>
        <column name="createdby" type="varchar(255)"/>
        <column name="updatedby" type="varchar(255)"/>
        <column name="createdat" type="timestamp"/>
        <column name="updatedat" type="timestamp"/>
        <column name="tipo" type="varchar(255)"/>
        <column name="geometry_data" type="jsonb"/>
        <column name="centroide_lat" type="decimal"/>
        <column name="centroide_lon" type="decimal"/>
        <column name="padre" type="int"/>
        <column name="nivel" type="int"/>
        <column name="activo" type="boolean"/>
        <column name="created_at" type="timestamp"/>
        <column name="updated_at" type="timestamp"/>

    </createTable>
</changeSet>
</databaseChangeLog>
