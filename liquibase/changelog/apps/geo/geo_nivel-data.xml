    <changeSet id="geo_nivel-pais" author="orco">
        <insert tableName="geo_nivel">
            <column name="id" valueComputed="nextval('geo_nivel_id_seq')"/>
            <column name="codigo" value="PAIS"/>
            <column name="nombre" value="Pais"/>
            <column name="descripcion" value="GeoNivel Pais"/>

            <!-- BaseModel -->
            <column name="is_deleted" valueBoolean="false"/>
            <column name="createdat" valueDate="NOW()"/>
            <column name="updatedat" valueDate="NOW()"/>
            <column name="createdby" valueNumeric="null"/>
            <column name="updatedby" valueNumeric="null"/>

            <!-- ConstantModel -->
            <column name="activo" valueBoolean="true"/>

        </insert>
        <rollback>
            <delete tableName="geo_nivel">
                <where>codigo = 'PAIS'</where>
            </delete>
        </rollback>
    </changeSet>

