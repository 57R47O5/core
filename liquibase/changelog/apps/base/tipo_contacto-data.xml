<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="tipo_contacto-correo_electronico" author="orco">
        <insert tableName="tipo_contacto">
            <column name="id" valueComputed="nextval('tipo_contacto_id_seq')"/>
            <column name="codigo" value="CORREO_ELECTRONICO"/>
            <column name="nombre" value="Correo Electronico"/>
            <column name="descripcion" value="Correo Electronico"/>

            <!-- BaseModel -->
            <column name="is_deleted" valueBoolean="false"/>
            <column name="createdat" valueDate="NOW()"/>
            <column name="updatedat" valueDate="NOW()"/>
            <column name="createdby" valueNumeric="null"/>
            <column name="updatedby" valueNumeric="null"/>

            <!-- ConstantModel -->
            <column name="activo" valueBoolean="true"/>

        </insert>
        <rollback>
            <delete tableName="tipo_contacto">
                <where>codigo = 'CORREO_ELECTRONICO'</where>
            </delete>
        </rollback>
    </changeSet>

