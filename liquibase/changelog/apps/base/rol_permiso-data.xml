    <changeSet id="rol_permiso-base.base_viewer-base.persona-juridica.view" author="orco">
        <insert tableName="rol_permiso">
            <column name="id" valueComputed="nextval('rol_permiso_id_seq')"/>

            <column name="rol_code"
                valueComputed="(SELECT id FROM rol WHERE codigo = 'base.BASE_VIEWER')"/>

            <column name="permiso_code"
                valueComputed="(SELECT id FROM permiso WHERE codigo = 'base.persona-juridica.view')"/>

            <column name="is_deleted" valueBoolean="false"/>
            <column name="createdat" valueDate="NOW()"/>
            <column name="updatedat" valueDate="NOW()"/>
            <column name="createdby" valueNumeric="null"/>
            <column name="updatedby" valueNumeric="null"/>
        </insert>

        <rollback>
            <delete tableName="rol_permiso">
                <where>
                    rol_code = (SELECT id FROM rol WHERE codigo = 'base.BASE_VIEWER')
                    AND
                    permiso_code = (SELECT id FROM permiso WHERE codigo = 'base.persona-juridica.view')
                </where>
            </delete>
        </rollback>
    </changeSet>

